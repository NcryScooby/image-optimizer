              "body": "{\n  \"status\": \"ok\"\n}"
            }
          ]
        },
        {
          "name": "GET Ready (API)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ready",
              "host": ["{{baseUrl}}"],
              "path": ["ready"]
            },
            "description": "Readiness: ping Postgres + RabbitMQ.\n\n**200** — deps ok\n```json\n{\"status\":\"ok\",\"checks\":{\"postgres\":\"ok\",\"rabbitmq\":\"ok\"}}\n```\n\n**503** — algum check fail (`status: not_ready`)."
          },
          "response": [
            {
              "name": "OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/ready",
                  "host": ["{{baseUrl}}"],
                  "path": ["ready"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"status\": \"ok\",\n  \"checks\": {\n    \"postgres\": \"ok\",\n    \"rabbitmq\": \"ok\"\n  }\n}"
            },
            {
              "name": "Not Ready (postgres fail)",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/ready",
                  "host": ["{{baseUrl}}"],
                  "path": ["ready"]
                }
              },
              "status": "Service Unavailable",
              "code": 503,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"status\": \"not_ready\",\n  \"checks\": {\n    \"postgres\": \"fail\",\n    \"rabbitmq\": \"ok\"\n  }\n}"
            }
          ]
        },
