                  "key": "h",
                  "value": "200",
                  "description": "Height (int > 0)"
                },
                {
                  "key": "fit",
                  "value": "cover",
                  "description": "cover | contain | fill"
                },
                {
                  "key": "crop",
                  "value": "center",
                  "description": "center | top | bottom | left | right"
                },
                {
                  "key": "q",
                  "value": "80",
                  "description": "Quality 1–100 (default 80)"
                }
              ]
            },
            "description": "Serve variante AVIF sob demanda. Cold miss gera inline (imgproxy) e responde `200` — **sem** `202`.\n\n| Situação | HTTP | Notas |\n| --- | --- | --- |\n| Pronta / gerada | `200` | body = bytes AVIF, `Content-Type: image/avif` |\n| Failed | `422` | JSON erro |\n| Timeout sync | `503` | |\n| Imagem inexistente | `404` | |\n| Params inválidos | `400` | |"
          },
          "response": [
            {
              "name": "OK (AVIF)",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/images/{{imageId}}?w=300&h=200&fit=cover&crop=center&q=80",
                  "host": ["{{baseUrl}}"],
                  "path": ["images", "{{imageId}}"],
                  "query": [
                    { "key": "w", "value": "300" },
                    { "key": "h", "value": "200" },
                    { "key": "fit", "value": "cover" },
                    { "key": "crop", "value": "center" },
                    { "key": "q", "value": "80" }
                  ]
                }
