            "header": [],
            "url": {
              "raw": "{{baseUrl}}/images/{{imageId}}",
              "host": ["{{baseUrl}}"],
              "path": ["images", "{{imageId}}"]
            },
            "description": "Sem query params → variante identity: AVIF full-size com quality default (80).\n\nMesmo contrato de status: `202` → poll → `200`."
          },
